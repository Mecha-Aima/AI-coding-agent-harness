# Klauso — copy to your workspace as `.env`
# Direct Anthropic (default). Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Claude Sonnet 4.5 (Messages API snapshot)
MODEL_ID=claude-sonnet-4-5-20250929

# Optional: only for a compatible HTTP gateway (e.g. corporate proxy or LiteLLM)
# ANTHROPIC_BASE_URL=

# anthropic | off — off disables prompt cache markers (e.g. some proxies)
CACHE_MODE=anthropic

# 1 = JSONL teammates + threads; 0 = lead only
ENABLE_TEAMS=1

# 1 = background workers claim tasks from .agent_tasks.json
ENABLE_AUTONOMOUS_WORKERS=0

# HARNESS_DEBUG=1

# Optional: Klauso path overrides (otherwise ./config, ./skills, cwd workspace)
# KLAUSO_WORKSPACE=/path/to/project
# KLAUSO_CONFIG_DIR=/path/to/config_dir
# KLAUSO_SKILLS_DIR=/path/to/skills

# GitHub MCP (when using default mcp_config github server)
# GITHUB_TOKEN=
